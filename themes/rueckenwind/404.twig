{% extends 'layout.twig' %}

{% block title %}404 – Page not found | {{ settings.title }}{% endblock %}

{% block sidebar_wrapper %}{% endblock %}

{% block content %}
<div class="flex flex-1 items-center justify-center px-6 py-24">
  <div class="max-w-md rounded-3xl border border-gray-200/80 bg-white/85 px-8 py-10 text-center shadow-xl shadow-gray-950/8 ring-1 ring-gray-950/5 dark:border-gray-800/80 dark:bg-gray-900/80 dark:ring-white/10">

    <div class="mb-4 select-none text-8xl font-black leading-none text-primary-500 dark:text-primary-400">
      404
    </div>

    <h1 class="mb-3 text-2xl font-semibold text-gray-950 dark:text-white">
      {{ title|default('Page not found') }}
    </h1>

    <p class="mb-8 leading-relaxed text-gray-500 dark:text-gray-400">
      {{ description|default('The page you were looking for does not exist or has been moved.') }}
    </p>

    <a href="{{ base_url }}"
       class="inline-flex items-center gap-2 rounded-full bg-primary-600 px-6 py-2.5 font-medium text-white shadow-lg shadow-primary-600/20 transition-colors hover:bg-primary-700">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
      </svg>
      Back to homepage
    </a>

  </div>
</div>
{% endblock %}
