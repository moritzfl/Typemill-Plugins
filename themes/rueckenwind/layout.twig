{% set theme = settings.themes.rueckenwind %}
{% set showSidebarNav = showSidebarNav|default(true) %}
<!DOCTYPE html>
<html lang="{{ settings.langattr | default('en') }}" class="scroll-smooth scheme-light dark:scheme-dark">
<head>
  {# ── Anti-flash: apply saved theme before any paint ───────────── #}
  <script>
    (function () {
      try {
        var t = localStorage.getItem('wfb-theme');
        if (t === 'dark' || (t !== 'light' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      } catch (e) {}
    })();
  </script>

  <meta charset="UTF-8">
  <title>{% block title %}{% endblock %}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="color-scheme" content="light dark" />
  <meta name="description" content="{{ metatabs.meta.description }}" />
  <meta name="author" content="{{ metatabs.meta.author }}" />
  <meta name="generator" content="TYPEMILL" />
  <link rel="canonical" href="{{ item.urlAbs }}" />

  {{ assets.renderMeta() }}

  {% block stylesheets %}
  <link rel="stylesheet" href="{{ base_url }}/themes/rueckenwind/css/theme.css" />
  <style>
    :root {
      --rw-accent-500: {{ theme.accentColor | default('#3893F8') }};
      --rw-accent-600: {{ theme.accentColorDark | default('#2563eb') }};
      --rw-accent-50: color-mix(in srgb, white 92%, var(--rw-accent-500));
      --rw-accent-100: color-mix(in srgb, white 84%, var(--rw-accent-500));
      --rw-accent-200: color-mix(in srgb, white 72%, var(--rw-accent-500));
      --rw-accent-300: color-mix(in srgb, white 56%, var(--rw-accent-500));
      --rw-accent-400: color-mix(in srgb, white 34%, var(--rw-accent-500));
      --rw-accent-700: color-mix(in srgb, black 14%, var(--rw-accent-600));
      --rw-accent-800: color-mix(in srgb, black 26%, var(--rw-accent-600));
      --rw-accent-900: color-mix(in srgb, black 40%, var(--rw-accent-600));
    }
    {% if theme.customcss %}
    {{ theme.customcss }}
    {% endif %}
  </style>
  {% endblock %}
</head>
<body class="flex h-screen min-h-screen flex-col overflow-hidden bg-white text-gray-800 antialiased dark:bg-gray-950 dark:text-gray-100">

  <a href="#main-content" class="skip-link">Skip to content</a>

  {# ── Admin bar ─────────────────────────────────────────────────── #}
  {% if is_loggedin() %}
  <div class="fixed top-0 right-0 z-50 rounded-bl-xl bg-primary-600 px-3 py-1 text-[11px] font-medium text-white shadow-lg shadow-primary-600/20">
    <a href="{{ base_url }}/tm/account" class="text-white hover:text-primary-100 transition-colors">&#9881; Admin</a>
  </div>
  {% endif %}

  {# ── Top navigation bar ────────────────────────────────────────── #}
  <header id="topbar" class="sticky top-0 z-40 flex h-14 items-center border-b border-gray-200/80 bg-white/80 shadow-sm shadow-gray-950/5 backdrop-blur-xl dark:border-gray-800/80 dark:bg-gray-950/75">
    <div class="flex w-full items-center justify-between gap-4 px-4 sm:px-6">

      <a href="{{ base_url }}" class="flex shrink-0 items-center gap-2.5 text-lg font-semibold tracking-tight text-gray-900 transition-colors hover:text-primary-600 dark:text-white dark:hover:text-primary-300">
        {% if logo %}
          <img src="{{ base_url }}/{{ logo }}" alt="{{ settings.title|e }}" class="h-8 w-auto rounded-md" />
        {% else %}
          <span>{{ settings.title|e }}</span>
        {% endif %}
      </a>

      {# Mobile sidebar toggle #}
      {% block mobile_nav_toggle %}
      <button id="mobile-menu-btn"
              type="button"
              aria-label="Toggle navigation"
              aria-expanded="false"
              aria-controls="sidebar"
              class="rounded-full border border-gray-200 bg-white/80 p-2 text-gray-500 shadow-sm shadow-gray-950/5 transition-colors hover:text-gray-900 dark:border-gray-800 dark:bg-gray-900/80 dark:text-gray-400 dark:hover:text-white lg:hidden">
        <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      {% endblock %}

    </div>
  </header>

  {# ── Page content ──────────────────────────────────────────────── #}
  <div class="flex min-h-0 w-full flex-1 overflow-hidden">

    {# ── Sidebar ───────────────────────────────────────────────────── #}
    {% block sidebar_wrapper %}
    <div id="mobile-backdrop" class="hidden fixed inset-0 z-20 bg-gray-950/30 backdrop-blur-sm lg:hidden"></div>
    <aside id="sidebar"
           class="hidden lg:flex w-72 shrink-0 flex-col border-r border-gray-200/70 bg-white/72 backdrop-blur-sm dark:border-gray-800/80 dark:bg-gray-950/70 xl:w-80">

      {# Scrollable nav area #}
      <div class="sidebar-scroll flex-1 overflow-y-auto px-3 py-6 sm:px-4">

        {% if multilang is defined and multilang %}
          <div class="mb-5 flex flex-wrap gap-1.5 border-b border-gray-200/80 pb-4 dark:border-gray-700/80">
            {% for lang, link in multilang %}
              <a href="{{ base_url }}{{ link }}" class="rounded-full border border-gray-200 bg-white/80 px-2.5 py-1 text-xs font-medium text-gray-600 shadow-sm shadow-gray-950/5 transition-colors hover:border-primary-300 hover:text-primary-700 dark:border-gray-700 dark:bg-gray-900/70 dark:text-gray-300 dark:hover:border-primary-700 dark:hover:text-primary-200">{{ lang }}</a>
            {% endfor %}
          </div>
        {% endif %}

        {% block sidebar %}
          {% include 'partials/navigation.twig' %}
        {% endblock %}

        {% if widgets is defined and widgets %}
          <div class="mt-6 space-y-4">
            {% for index, widget in widgets %}
              <div id="{{ index }}">{{ widget }}</div>
            {% endfor %}
          </div>
        {% endif %}

      </div>

      {# Pinned bottom: theme switcher #}
      <div class="shrink-0 border-t border-gray-200/80 bg-white/60 px-3 py-3 dark:border-gray-700/80 dark:bg-gray-950/40">
        {% include 'partials/colormode.twig' %}
      </div>

    </aside>
    {% endblock %}

    {# ── Main slot + footer, scrolls together ──────────────────────── #}
    <div class="content-scroll flex-1 min-w-0 overflow-y-auto flex flex-col">
      {% block content %}{% endblock %}
      {% include 'partials/footer.twig' %}
    </div>

  </div>

  {% block javascripts %}
  {{ assets.renderCSS() }}
  {{ assets.renderJS() }}
  <script>
    (function () {
      // ── Theme switcher ─────────────────────────────────────────────
      function wfbApply(theme) {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else if (theme === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          // system
          if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }
      }

      function wfbStoredTheme() {
        try {
          return localStorage.getItem('wfb-theme');
        } catch (e) {
          return null;
        }
      }

      function wfbPersistTheme(theme) {
        try {
          if (theme === 'system') {
            localStorage.removeItem('wfb-theme');
          } else {
            localStorage.setItem('wfb-theme', theme);
          }
        } catch (e) {}
      }

      function wfbSetTheme(theme) {
        wfbPersistTheme(theme);
        wfbApply(theme);
        wfbUpdateButtons(theme);
      }

      function wfbCurrentTheme() {
        return wfbStoredTheme() || 'system';
      }

      function wfbUpdateButtons(theme) {
        document.querySelectorAll('[data-theme-btn]').forEach(function (btn) {
          var active = btn.dataset.themeBtn === theme;
          btn.classList.toggle('active-theme', active);
          btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      }

      // Expose theme setter for optional external integrations
      window.wfbSetTheme = wfbSetTheme;

      // Wire up system preference listener
      var wfbColorScheme = window.matchMedia('(prefers-color-scheme: dark)');
      function wfbHandleSystemThemeChange() {
        if (!wfbStoredTheme()) {
          wfbApply('system');
          wfbUpdateButtons('system');
        }
      }
      if (wfbColorScheme.addEventListener) {
        wfbColorScheme.addEventListener('change', wfbHandleSystemThemeChange);
      } else if (wfbColorScheme.addListener) {
        wfbColorScheme.addListener(wfbHandleSystemThemeChange);
      }

      // Init button states once DOM is ready
      document.addEventListener('DOMContentLoaded', function () {
        var initialTheme = wfbCurrentTheme();
        wfbApply(initialTheme);
        wfbUpdateButtons(initialTheme);

        document.querySelectorAll('[data-theme-target]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            wfbSetTheme(btn.dataset.themeTarget);
          });
        });

        document.querySelectorAll('[data-print-page]').forEach(function (btn) {
          btn.addEventListener('click', function () {
            window.print();
          });
        });
      });

      // ── Mobile sidebar toggle (right-side drawer) ─────────────────
      const btn       = document.getElementById('mobile-menu-btn');
      const sidebar   = document.getElementById('sidebar');
      const backdrop  = document.getElementById('mobile-backdrop');
      const iconOpen  = document.getElementById('menu-icon-open');
      const iconClose = document.getElementById('menu-icon-close');

      const MOBILE_OPEN  = ['fixed', 'top-14', 'right-0', 'bottom-0', 'z-30', 'flex', 'border-l', 'border-gray-200', 'bg-white/95', 'backdrop-blur-xl', 'shadow-2xl', 'shadow-gray-950/20', 'dark:border-gray-800', 'dark:bg-gray-950/95'];
      const DESKTOP_MEDIA = window.matchMedia('(min-width: 1024px)');

      function openMobileMenu() {
        MOBILE_OPEN.forEach(function (c) { sidebar.classList.add(c); });
        sidebar.classList.remove('hidden');
        backdrop.classList.remove('hidden');
        btn.setAttribute('aria-expanded', 'true');
        iconOpen.classList.add('hidden');
        iconClose.classList.remove('hidden');
      }

      function closeMobileMenu() {
        sidebar.classList.add('hidden');
        MOBILE_OPEN.forEach(function (c) { sidebar.classList.remove(c); });
        backdrop.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
      }

      function syncMenuToViewport() {
        if (DESKTOP_MEDIA.matches) {
          closeMobileMenu();
        }
      }

      if (btn && sidebar && backdrop && iconOpen && iconClose) {
        btn.addEventListener('click', function () {
          sidebar.classList.contains('hidden') ? openMobileMenu() : closeMobileMenu();
        });

        backdrop.addEventListener('click', closeMobileMenu);

        sidebar.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () {
            if (window.innerWidth < 1024) closeMobileMenu();
          });
        });

        if (DESKTOP_MEDIA.addEventListener) {
          DESKTOP_MEDIA.addEventListener('change', syncMenuToViewport);
        } else if (DESKTOP_MEDIA.addListener) {
          DESKTOP_MEDIA.addListener(syncMenuToViewport);
        }

        window.addEventListener('resize', syncMenuToViewport);
        syncMenuToViewport();
      }
    })();

    // ── Nav folder toggle ─────────────────────────────────────────
    document.querySelectorAll('[data-nav-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var li  = btn.closest('li');
        var controls = btn.getAttribute('aria-controls');
        var ul  = controls ? document.getElementById(controls) : li.querySelector('ul');
        if (!ul) return;
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', open ? 'false' : 'true');
        ul.classList.toggle('hidden', open);
        btn.querySelector('[data-icon-plus]').classList.toggle('hidden', !open);
        btn.querySelector('[data-icon-minus]').classList.toggle('hidden', open);
      });
    });

    // ── SVG dark-mode invert ───────────────────────────────────────
    (function () {
      var ALLOWED = /^(none|transparent|currentcolor|inherit|black|white|#000|#000000|#fff|#ffffff|rgb\(\s*0\s*,\s*0\s*,\s*0\s*\)|rgb\(\s*255\s*,\s*255\s*,\s*255\s*\))$/i;
      var COLOR_RE = /(?:fill|stroke|stop-color|color)\s*[=:]\s*["']?\s*([^"'\s;,><\/]+)/gi;

      function isBwSvg(text) {
        var m;
        COLOR_RE.lastIndex = 0;
        while ((m = COLOR_RE.exec(text)) !== null) {
          if (!ALLOWED.test(m[1].trim())) return false;
        }
        return true;
      }

      function checkImg(img) {
        var src = img.getAttribute('src');
        if (!src || !/\.svg(\?|$)/i.test(src)) return;
        var a = document.createElement('a');
        a.href = src;
        if (a.hostname && a.hostname !== location.hostname) return;
        fetch(src, {credentials: 'same-origin'})
          .then(function (r) { return r.ok ? r.text() : Promise.reject(); })
          .then(function (text) { if (isBwSvg(text)) img.classList.add('svg-bw-invert'); })
          .catch(function () {});
      }

      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('img').forEach(checkImg);
      });
    })();
  </script>
  {% endblock %}

</body>
</html>
