<div class="flex items-center justify-between gap-4 text-sm">

  {# Crumb trail #}
  <nav aria-label="Breadcrumb" class="min-w-0 rounded-full border border-gray-200/80 bg-white/80 px-3 py-2 text-gray-500 shadow-sm shadow-gray-950/5 dark:border-gray-800/80 dark:bg-gray-900/70 dark:text-gray-400">
    <div class="flex min-w-0 flex-wrap items-center gap-1">

      <a href="{{ base_url }}" class="shrink-0 transition-colors hover:text-primary-600 dark:hover:text-primary-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
        </svg>
      </a>

      {% if settings.currentproject %}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        <a href="{{ base_url }}/{{ settings.currentproject }}" class="truncate transition-colors hover:text-primary-600 dark:hover:text-primary-300">{{ settings.currentproject }}</a>
      {% endif %}

      {% for crumb in breadcrumb %}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
        {% if loop.last %}
          <span class="truncate text-gray-700 dark:text-gray-300">{{ crumb.name|e }}</span>
        {% else %}
          <a href="{{ crumb.urlRel }}" class="truncate transition-colors hover:text-primary-600 dark:hover:text-primary-300">{{ crumb.name|e }}</a>
        {% endif %}
      {% endfor %}

    </div>
  </nav>

  {# Prev / Next inline #}
  <div class="hidden shrink-0 items-center gap-2 text-gray-400 dark:text-gray-500 sm:flex">
    {% if item.prevItem %}
      <a href="{{ item.prevItem.urlRel }}" title="{{ item.prevItem.name }}"
         class="flex items-center gap-1 rounded-full border border-gray-200/80 bg-white/80 px-3 py-1.5 shadow-sm shadow-gray-950/5 transition-colors hover:text-primary-500 dark:border-gray-800/80 dark:bg-gray-900/70 dark:hover:text-primary-300">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        <span class="text-xs">{{ settings.themes.rueckenwind.previous|default('Prev') }}</span>
      </a>
    {% endif %}
    {% if item.nextItem %}
      <a href="{{ item.nextItem.urlRel }}" title="{{ item.nextItem.name }}"
         class="flex items-center gap-1 rounded-full border border-gray-200/80 bg-white/80 px-3 py-1.5 shadow-sm shadow-gray-950/5 transition-colors hover:text-primary-500 dark:border-gray-800/80 dark:bg-gray-900/70 dark:hover:text-primary-300">
        <span class="text-xs">{{ settings.themes.rueckenwind.next|default('Next') }}</span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    {% endif %}
  </div>

</div>
