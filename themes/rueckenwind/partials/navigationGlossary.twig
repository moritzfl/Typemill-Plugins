{% set currentLetter = '' %}

{% for element in glossary|sort((a, b) => a.name <=> b.name) %}
  {% set letter = element.name|first|upper %}
  {% if letter != currentLetter %}
    {% set currentLetter = letter %}
    <h2 class="text-lg font-bold text-gray-400 dark:text-gray-500 mt-8 mb-2 border-b border-gray-200 dark:border-gray-700 pb-1">{{ letter }}</h2>
  {% endif %}
  <a href="{{ element.urlAbs }}"
     class="block py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
    {{ element.name }}
  </a>
{% endfor %}
