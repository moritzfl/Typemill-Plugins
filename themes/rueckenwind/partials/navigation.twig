{% macro nav_items(items) %}
  {% import _self as m %}
  {% for element in items %}
    {% set depth = element.keyPathArray|length %}
    {% set hasChildren = element.elementType == 'folder' and element.folderContent|length > 0 and element.contains == 'pages' %}
    {% set expanded = element.active or element.activeParent %}
    {% set submenuId = 'nav-subtree-' ~ (element.keyPathArray|join('-')) %}

    <li>
      <div class="flex items-center gap-0.5">

        <a href="{{ element.urlRel }}"
           class="nav-indent-{{ depth }} flex-1 flex items-center gap-2 rounded-xl px-3 py-2 text-sm transition-colors
             {%- if element.active %} bg-primary-100/85 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 font-medium ring-1 ring-inset ring-primary-300 dark:ring-primary-700 shadow-sm shadow-primary-500/10
             {%- elseif element.activeParent %} bg-white/70 dark:bg-gray-900/60 text-gray-900 dark:text-white font-semibold
             {%- else %} text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 hover:bg-white/80 dark:hover:bg-gray-900/80
             {%- endif %}">

          {%- if element.elementType == 'folder' -%}
            {%- if element.activeParent or element.active -%}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9a2 2 0 00-2 2v5a2 2 0 01-2 2z"/>
              </svg>
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 shrink-0 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/>
              </svg>
            {%- endif -%}
          {%- else -%}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 shrink-0 opacity-30" fill="currentColor" viewBox="0 0 8 8">
              <circle cx="4" cy="4" r="3"/>
            </svg>
          {%- endif -%}

          <span class="truncate">{% if settings.themes.rueckenwind.chapnum and element.chapter %}{{ element.chapter }}&nbsp;{% endif %}{{ element.name }}</span>

        </a>

        {%- if hasChildren -%}
          <button type="button"
                  data-nav-toggle
                  aria-expanded="{{ expanded ? 'true' : 'false' }}"
                  aria-controls="{{ submenuId }}"
                  aria-label="Toggle {{ element.name }}"
                  class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full text-gray-400 transition-colors hover:bg-white/80 hover:text-gray-700 dark:hover:bg-gray-900/80 dark:hover:text-gray-200">
            <svg data-icon-plus xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 {{ expanded ? 'hidden' : '' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            <svg data-icon-minus xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 {{ expanded ? '' : 'hidden' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/>
            </svg>
          </button>
        {%- endif -%}

      </div>
      
      {%- if hasChildren -%}
        <ul id="{{ submenuId }}" class="{{ expanded ? '' : 'hidden' }} mt-1 ml-2 space-y-0.5 border-l border-gray-200/80 pl-2 dark:border-gray-700/80">
          {{ m.nav_items(element.folderContent) }}
        </ul>
      {%- endif -%}

    </li>
  {% endfor %}
{% endmacro %}

{% import _self as nav %}

<nav aria-label="Site navigation">
  <ul class="space-y-0.5">
    {{ nav.nav_items(navigation) }}
  </ul>
</nav>
