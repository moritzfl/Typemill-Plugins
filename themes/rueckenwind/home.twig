{# ── Hero section (only shown when hero content is configured) ──────── #}
{% if settings.themes.rueckenwind.heroTitle or settings.themes.rueckenwind.heroSubtitle or settings.themes.rueckenwind.heroBtnLabel %}
<section class="w-full overflow-hidden border-b border-gray-200/80 bg-linear-to-br from-primary-50 via-white to-gray-50 dark:border-gray-800/80 dark:from-gray-900 dark:via-gray-950 dark:to-gray-900">
  <div class="mx-auto max-w-screen-xl px-6 py-12 sm:py-16">

    <h1 class="max-w-3xl text-3xl font-semibold leading-tight tracking-tight text-gray-950 dark:text-white sm:text-4xl lg:text-5xl">
      {{ settings.themes.rueckenwind.heroTitle | default(settings.title) | e }}
    </h1>

    {% if settings.themes.rueckenwind.heroSubtitle %}
      <p class="mt-4 max-w-2xl text-base/8 text-gray-600 dark:text-gray-300 sm:text-lg/8">
        {{ settings.themes.rueckenwind.heroSubtitle | e }}
      </p>
    {% endif %}

    {% if settings.themes.rueckenwind.heroBtnLink and settings.themes.rueckenwind.heroBtnLabel %}
      <div class="mt-6">
        <a href="{{ settings.themes.rueckenwind.heroBtnLink }}"
           class="inline-flex items-center gap-2 rounded-full bg-primary-600 px-5 py-2.5 text-sm font-medium text-white shadow-lg shadow-primary-600/20 transition-colors hover:bg-primary-700 dark:shadow-primary-950/40">
          {{ settings.themes.rueckenwind.heroBtnLabel | e }}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    {% endif %}

  </div>
</section>
{% endif %}

{# ── Home page content (Markdown body) ────────────────────────────── #}
{% if content %}
  <div class="mx-auto max-w-screen-xl px-4 py-12 sm:px-6 lg:px-10">
    <article class="prose max-w-3xl mx-auto">
      {{ content }}
    </article>
  </div>
{% endif %}
