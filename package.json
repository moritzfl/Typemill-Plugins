{
  "name": "typemill-html-developer-mode",
  "private": true,
  "scripts": {
    "build": "npm run build:frontend",
    "build:frontend": "npm run build:rueckenwind",
    "build:rueckenwind": "tailwindcss -i ./themes/rueckenwind/styles/tailwind.css -o ./themes/rueckenwind/css/theme.css --minify",
    "watch:rueckenwind": "tailwindcss -i ./themes/rueckenwind/styles/tailwind.css -o ./themes/rueckenwind/css/theme.css --watch",
    "update:mergely": "node ./scripts/update-mergely.mjs",
    "sync:frontend": "npm run build:rueckenwind && npm run update:mergely"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.2",
    "mergely": "5.4.7",
    "tailwindcss": "4.2.2"
  }
}

